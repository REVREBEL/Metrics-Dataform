config {
  type: "operations",
  hasOutput: false,
  tags: ["ddl", "pace", "facts"]
}

CREATE TABLE IF NOT EXISTS `${dataform.projectConfig.defaultDatabase}.${dataform.projectConfig.defaultDataset}.fact_pace_property` (
  property_code STRING OPTIONS(description="Property code."),
  property_name STRING OPTIONS(description="Property name."),
  snap_date DATE OPTIONS(description="Date when the data snapshot was taken."),
  stay_date DATE OPTIONS(description="Hotel stay, occupancy, or service date for which the metrics apply."),
  available_rms INT64 OPTIONS(description="Available room inventory for the property and stay date."),
  available_rms_ly INT64 OPTIONS(description="Available room inventory for the comparable prior-year stay date."),
  rms_otb INT64 OPTIONS(description="Rooms on the books for the stay date as of the snapshot date."),
  rev_otb FLOAT64 OPTIONS(description="Room revenue on the books for the stay date as of the snapshot date."),
  rms_ly INT64 OPTIONS(description="Actual rooms for the comparable prior-year stay date."),
  rev_ly FLOAT64 OPTIONS(description="Actual room revenue for the comparable prior-year stay date."),
  rms_stly INT64 OPTIONS(description="Rooms on the books for the stay date at the same time last year."),
  rev_stly FLOAT64 OPTIONS(description="Room revenue on the books for the stay date at the same time last year."),
  rms_st2y INT64 OPTIONS(description="Rooms on the books for the stay date at the same time two years ago."),
  rev_st2y FLOAT64 OPTIONS(description="Room revenue on the books for the stay date at the same time two years ago."),
  rms_st3y INT64 OPTIONS(description="Rooms on the books for the stay date at the same time three years ago."),
  rev_st3y FLOAT64 OPTIONS(description="Room revenue on the books for the stay date at the same time three years ago."),
  rms_st4y INT64 OPTIONS(description="Rooms on the books for the stay date at the same time four years ago."),
  rev_st4y FLOAT64 OPTIONS(description="Room revenue on the books for the stay date at the same time four years ago."),
  rms_bgt INT64 OPTIONS(description="Budgeted rooms for the stay date."),
  rev_bgt FLOAT64 OPTIONS(description="Budgeted room revenue for the stay date."),
  rms_fct INT64 OPTIONS(description="Forecasted rooms for the stay date."),
  rev_fct FLOAT64 OPTIONS(description="Forecasted room revenue for the stay date."),
  adr_fct FLOAT64 OPTIONS(description="Forecasted ADR for the stay date."),
  cx_rms INT64 OPTIONS(description="Cancelled rooms for the stay date."),
  cx_rms_ly INT64 OPTIONS(description="Cancelled rooms for the comparable prior-year stay date."),
  ns_rms INT64 OPTIONS(description="No-show rooms for the stay date."),
  ns_rms_ly INT64 OPTIONS(description="No-show rooms for the comparable prior-year stay date."),
  demand_total INT64 OPTIONS(description="Total demand for the property and stay date."),
  demand_total_ly INT64 OPTIONS(description="Total demand for the comparable prior-year stay date."),
  demand_group INT64 OPTIONS(description="Group demand for the property and stay date."),
  demand_group_ly INT64 OPTIONS(description="Group demand for the comparable prior-year stay date."),
  demand_transient INT64 OPTIONS(description="Transient demand for the property and stay date."),
  demand_transient_ly INT64 OPTIONS(description="Transient demand for the comparable prior-year stay date."),
  ooo_rms INT64 OPTIONS(description="Out-of-order rooms for the stay date."),
  ooo_rms_ly INT64 OPTIONS(description="Out-of-order rooms for the comparable prior-year stay date."),
  lrv FLOAT64 OPTIONS(description="Last room value for the property and stay date."),
  wash_pct FLOAT64 OPTIONS(description="Wash percentage for the property and stay date."),
  wash_pct_ly FLOAT64 OPTIONS(description="Wash percentage for the comparable prior-year stay date."),
  bar_price FLOAT64 OPTIONS(description="Best available rate price for the property and stay date."),
  source_system STRING OPTIONS(description="Source system."),
  source_report STRING OPTIONS(description="Source report."),
  source_file STRING OPTIONS(description="Source file."),
  insert_date DATE OPTIONS(description="Insert date."),
  updated_date DATE OPTIONS(description="Updated date.")
)
PARTITION BY snap_date
CLUSTER BY property_code, stay_date
OPTIONS(description="Property-level on-the-books pace snapshot metrics.");

CREATE TABLE IF NOT EXISTS `${dataform.projectConfig.defaultDatabase}.${dataform.projectConfig.defaultDataset}.fact_pace_segment` (
  property_code STRING OPTIONS(description="Property code."),
  property_name STRING OPTIONS(description="Property name."),
  snap_date DATE OPTIONS(description="Date when the data snapshot was taken."),
  stay_date DATE OPTIONS(description="Hotel stay, occupancy, or service date for which the metrics apply."),
  segment STRING OPTIONS(description="Standard segment."),
  segment_code STRING OPTIONS(description="Standard segment code."),
  segment_group STRING OPTIONS(description="Standard segment group."),
  segment_group_code STRING OPTIONS(description="Standard segment group code."),
  finance_segment STRING OPTIONS(description="Finance segment."),
  finance_segment_code STRING OPTIONS(description="Finance segment code."),
  segment_category STRING OPTIONS(description="Standard segment category."),
  rate_basis STRING OPTIONS(description="Rate basis for segment revenue interpretation."),
  segment_map STRING OPTIONS(description="Source segment value."),
  segment_code_map STRING OPTIONS(description="Source segment code."),
  rms_otb INT64 OPTIONS(description="Rooms on the books."),
  rev_otb FLOAT64 OPTIONS(description="Room revenue on the books."),
  rms_ly INT64 OPTIONS(description="Actual rooms for the comparable prior-year stay date."),
  rev_ly FLOAT64 OPTIONS(description="Actual room revenue for the comparable prior-year stay date."),
  rms_stly INT64 OPTIONS(description="Rooms on the books at same time last year."),
  rev_stly FLOAT64 OPTIONS(description="Room revenue on the books at same time last year."),
  rms_st2y INT64 OPTIONS(description="Rooms on the books at same time two years ago."),
  rev_st2y FLOAT64 OPTIONS(description="Room revenue on the books at same time two years ago."),
  rms_st3y INT64 OPTIONS(description="Rooms on the books at same time three years ago."),
  rev_st3y FLOAT64 OPTIONS(description="Room revenue on the books at same time three years ago."),
  rms_st4y INT64 OPTIONS(description="Rooms on the books at same time four years ago."),
  rev_st4y FLOAT64 OPTIONS(description="Room revenue on the books at same time four years ago."),
  rms_bgt INT64 OPTIONS(description="Budgeted rooms."),
  rev_bgt FLOAT64 OPTIONS(description="Budgeted room revenue."),
  rms_fct INT64 OPTIONS(description="Forecasted rooms."),
  rev_fct FLOAT64 OPTIONS(description="Forecasted room revenue."),
  cx_rms INT64 OPTIONS(description="Cancelled rooms."),
  cx_rms_ly INT64 OPTIONS(description="Cancelled rooms for the comparable prior-year stay date."),
  ns_rms INT64 OPTIONS(description="No-show rooms."),
  ns_rms_ly INT64 OPTIONS(description="No-show rooms for the comparable prior-year stay date."),
  source_system STRING OPTIONS(description="Source system."),
  source_report STRING OPTIONS(description="Source report."),
  source_file STRING OPTIONS(description="Source file."),
  insert_date DATE OPTIONS(description="Insert date."),
  updated_date DATE OPTIONS(description="Updated date.")
)
PARTITION BY snap_date
CLUSTER BY property_code, stay_date, segment_code
OPTIONS(description="Segment-level on-the-books pace snapshot metrics.");

CREATE TABLE IF NOT EXISTS `${dataform.projectConfig.defaultDatabase}.${dataform.projectConfig.defaultDataset}.fact_pace_source` (
  property_code STRING OPTIONS(description="Property code."),
  property_name STRING OPTIONS(description="Property name."),
