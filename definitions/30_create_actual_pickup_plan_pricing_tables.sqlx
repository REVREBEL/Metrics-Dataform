CREATE TABLE IF NOT EXISTS `${dataform.projectConfig.defaultDatabase}.${dataform.projectConfig.defaultDataset}.fact_pickup_property` (
  property_code STRING OPTIONS(description="Property code."),
  property_name STRING OPTIONS(description="Property name."),
  snap_date DATE OPTIONS(description="Snapshot date."),
  date DATE OPTIONS(description="Stay date."),
  comparison STRING OPTIONS(description="Comparison period such as cy, stly, st2y, st3y, or st4y."),
  pickup_window STRING OPTIONS(description="Pickup window such as 007, 014, 030, 060, or 090."),
  rms_pickup INT64 OPTIONS(description="Rooms pickup for the comparison/window."),
  rev_pickup FLOAT64 OPTIONS(description="Room revenue pickup for the comparison/window."),
  source_system STRING OPTIONS(description="Source system."),
  source_report STRING OPTIONS(description="Source report."),
  source_file STRING OPTIONS(description="Source file."),
  insert_date DATE OPTIONS(description="Insert date."),
  updated_date DATE OPTIONS(description="Updated date.")
)
PARTITION BY snap_date
CLUSTER BY property_code, date, comparison, pickup_window
OPTIONS(description="Property-level pickup metrics by comparison and pickup window.");

