config {
  type: "operations",
  hasOutput: false,
  tags: ["ddl", "facts", "actual", "pickup", "plan", "pricing"]
}

CREATE TABLE IF NOT EXISTS `${dataform.projectConfig.defaultDatabase}.${dataform.projectConfig.defaultDataset}.fact_actual_property` (
  property_code STRING OPTIONS(description="Property code."),
  property_name STRING OPTIONS(description="Property name."),
  date DATE OPTIONS(description="Business/stay date."),
  available_rms INT64 OPTIONS(description="Available room inventory."),
  rms INT64 OPTIONS(description="Actual rooms / room nights sold."),
  rev FLOAT64 OPTIONS(description="Actual room revenue."),
  fb_rev FLOAT64 OPTIONS(description="Actual food and beverage revenue."),
  other_rev FLOAT64 OPTIONS(description="Actual other revenue."),
  total_rev FLOAT64 OPTIONS(description="Actual total revenue."),
  guest_count INT64 OPTIONS(description="Actual guest count."),
  arrival_rms INT64 OPTIONS(description="Actual arrival rooms."),
  cx_rms INT64 OPTIONS(description="Cancelled rooms."),
  ns_rms INT64 OPTIONS(description="No-show rooms."),
  source_system STRING OPTIONS(description="Source system."),
  source_report STRING OPTIONS(description="Source report."),
  source_file STRING OPTIONS(description="Source file."),
  insert_date DATE OPTIONS(description="Insert date."),
  updated_date DATE OPTIONS(description="Updated date.")
)
PARTITION BY date
CLUSTER BY property_code
OPTIONS(description="Property-level actualized historical performance.");

CREATE TABLE IF NOT EXISTS `${dataform.projectConfig.defaultDatabase}.${dataform.projectConfig.defaultDataset}.fact_actual_segment` (
  property_code STRING OPTIONS(description="Property code."),
  property_name STRING OPTIONS(description="Property name."),
  date DATE OPTIONS(description="Business/stay date."),
  segment STRING OPTIONS(description="Standard segment."),
  segment_code STRING OPTIONS(description="Standard segment code."),
  segment_group STRING OPTIONS(description="Standard segment group."),
  segment_group_code STRING OPTIONS(description="Standard segment group code."),
  finance_segment STRING OPTIONS(description="Finance segment."),
  finance_segment_code STRING OPTIONS(description="Finance segment code."),
  segment_category STRING OPTIONS(description="Standard segment category."),
  rate_basis STRING OPTIONS(description="Rate basis for segment revenue interpretation."),
  segment_map STRING OPTIONS(description="Source segment value."),
  segment_code_map STRING OPTIONS(description="Source segment code."),
  available_rms INT64 OPTIONS(description="Available room inventory."),
  rms INT64 OPTIONS(description="Actual rooms / room nights sold."),
  rev FLOAT64 OPTIONS(description="Actual room revenue."),
  fb_rev FLOAT64 OPTIONS(description="Actual food and beverage revenue."),
  other_rev FLOAT64 OPTIONS(description="Actual other revenue."),
  total_rev FLOAT64 OPTIONS(description="Actual total revenue."),
  guest_count INT64 OPTIONS(description="Actual guest count."),
  arrival_rms INT64 OPTIONS(description="Actual arrival rooms."),
  cx_rms INT64 OPTIONS(description="Cancelled rooms."),
  ns_rms INT64 OPTIONS(description="No-show rooms."),
  source_system STRING OPTIONS(description="Source system."),
  source_report STRING OPTIONS(description="Source report."),
  source_file STRING OPTIONS(description="Source file."),
  insert_date DATE OPTIONS(description="Insert date."),
  updated_date DATE OPTIONS(description="Updated date.")
)
PARTITION BY date
CLUSTER BY property_code, segment_code
OPTIONS(description="Segment-level actualized historical performance.");

